# Supabase credentials
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Worker URL
# Deploy cloudflare-worker.js to Cloudflare Workers first
# Then add the Worker URL here (e.g., https://instagram-api-worker.YOUR_DOMAIN.workers.dev)
CF_WORKER_URL=https://instagram-api-worker.YOUR_DOMAIN.workers.dev

# Server config
PORT=3000

# Cache TTL in hours (default: 24)
CACHE_TTL_HOURS=24
