{
  "name": "@inflact-scraper/content-library",
  "version": "1.0.0",
  "description": "Production-grade browser session extractor and API utilization system for Inflact's Instagram Viewer endpoints",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx src/__tests__/test.ts",
    "example": "tsx examples/basic-usage.ts",
    "example:batch": "tsx examples/batch-scraping.ts",
    "clean": "rm -rf dist node_modules package-lock.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "inflact",
    "instagram",
    "scraper",
    "playwright",
    "browser-automation",
    "session-management",
    "api-interception"
  ],
  "author": "Inflact Scraper",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "node-cache": "^5.1.2",
    "playwright": "^1.59.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.5",
    "@types/node-cache": "^4.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
