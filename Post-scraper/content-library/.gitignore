.env
.env.local
.env.*.local

# Session & Cache
data/sessions/
logs/
downloads/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temp
*.tmp
*.temp
.tmp/

# System
.system
.cache
*.pid
