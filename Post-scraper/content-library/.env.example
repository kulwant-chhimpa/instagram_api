# Inflact Browser Session Extractor Configuration

# Browser Settings
BROWSER_HEADLESS=false
BROWSER_SLOWMO=100
BROWSER_TIMEOUT=30000
INFLACT_URL=https://inflact.com

# Session Storage
SESSION_DATA_PATH=./data/sessions
ENABLE_SESSION_PERSISTENCE=true

# API Configuration
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY=1000
API_TIMEOUT=30000
API_MAX_CONCURRENT_REQUESTS=5

# Proxy (optional)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# User Agent Rotation
ROTATE_USER_AGENTS=false

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Media Download (optional)
DOWNLOAD_MEDIA=false
MEDIA_OUTPUT_PATH=./downloads

# Performance
ENABLE_CACHE=true
CACHE_TTL=3600
MAX_BROWSER_POOL_SIZE=3
